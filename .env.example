# Copy to .env.local for local dev, and set the same in Vercel:
# Project → Settings → Environment Variables.

# --- Ops Copilot + AI agent drafting ---
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-haiku-latest   # optional

# --- Operator console auth (api/login, api/* guards) ---
OPERATOR_PASSWORD=change-me            # password to log into /admin (defaults to "moltbit-demo")
AUTH_SECRET=long-random-string-here    # HMAC signing secret for session tokens

# --- End-user wallets / login (Privy) ---
# Create an app at https://dashboard.privy.io → copy the App ID (public, safe to ship).
# Leave blank to run with the built-in mock login.
VITE_PRIVY_APP_ID=

# --- On-chain funding (USDC on Base) ---
# Where human deposits are sent (your vault/treasury address). Without it, deposits stay mock.
VITE_DEPOSIT_ADDRESS=
# Deployed MoltbitVault addresses (preferred over DEPOSIT_ADDRESS — mints shares at NAV).
# JSON map of strategyId -> vault address, plus optional "_default".
# e.g. {"funding-harvest-v3":"0x...","_default":"0x..."}
VITE_VAULTS=
# Live (mainnet, real third-party funds) is OFF until launch sign-off. Flip to "true"
# ONLY after audit + legal are complete (see LAUNCH_READINESS.md).
VITE_LIVE_ENABLED=false
# Optional custom RPC endpoints (defaults to the chain's public RPC):
# VITE_RPC_URL_BASE=
# VITE_RPC_URL_BASE_SEPOLIA=

# --- Agent execution gateway (api/orders) ---
AGENT_SECRET=another-long-random-string  # HMAC secret for scoped agent keys (mbk_…); defaults to AUTH_SECRET
                                         # NOTE: in production a weak/missing secret fails closed (503)
VENUE_MODE=mock                          # mock | live — live POSTs orders to VENUE_API_URL
# Live venue client (lib/venue.js submitLive) — your perp DEX / CEX order REST API:
# VENUE_API_URL=https://api.yourvenue.com/v1/orders
# VENUE_API_KEY=
# VENUE_NAME=hyperliquid
# Privy SERVER wallet (signs vault.allocate/reportNav/crank/setPaused — never exposed to agents).
# Set BOTH to enable real on-chain submission (lib/serverWallet.js → lib/chainServer.js):
# PRIVY_APP_ID=                           # same app as VITE_PRIVY_APP_ID
# PRIVY_APP_SECRET=                       # from the Privy dashboard
# PRIVY_API_URL=https://api.privy.io/v1   # override only if needed

# --- Settlement worker (api/cron/settle) ---
CRON_SECRET=yet-another-long-random-string  # guards the cron endpoint; Vercel Cron sends it as Bearer

# --- Ops alerting (reconcile breaks, halts, kill switch, failed crons) ---
# Slack/Discord/generic incoming webhook. Unset = log-only (still shows in Vercel logs).
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Database (optional; omit to run on in-memory seed data) ---
# Provision "KV" in the Vercel Storage tab — it injects these automatically:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
